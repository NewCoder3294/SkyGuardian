# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/

# Node
node_modules/
.next/
dist/
build/
*.log

# Packaged datasets + per-mission capture data — local generated artifacts
# (keep captures/README.md tracked; ignore the mission subdirectories under it)
datasets/
captures/*/

# Large binaries — distribute out-of-band. The whole models/yolo tree is
# treated as a local artifact: weights themselves never live in the repo, and
# operators sometimes symlink the directory across worktrees (see
# `backend/run-indoor.sh`'s MODELS path) so we keep the symlink out of git too.
models/**/*.pt
models/**/*.pth
models/**/*.onnx
models/**/*.bin
models/**/*.mlpackage
models/yolo
captures/**/*.mp4
captures/**/*.mov
captures/**/*.avi

# OS / editor
.DS_Store
.idea/
.vscode/
.claude/

# Conductor workspace scratch (attachments, pasted instructions, generated
# AprilTags, MediaMTX config). Never commit — local-only working state.
.context/

# Xcode / iOS
mobile/*.xcodeproj
mobile/DerivedData/
xcuserdata/
*.xcuserstate
mobile/build/
mobile/ExportOptions.plist.local
.gstack/
